# KIS OpenAPI (실전)
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
# (권장) kis_orb_vwap_bot과 동일 키
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=
# (호환) 구 키 이름도 지원
# KIS_CANO=
# KIS_ACNT_PRDT_CD=

# kis_orb_vwap_bot과 동일한 실전 안전장치(3중 게이트)
KIS_LIVE_ENABLED=0
KIS_LIVE_CONFIRM=NO
KIS_KILL_SWITCH=1

# (강력 추천) 전역 긴급 중단 파일
# touch STOP_TRADING.flag  # 생성하면 주문 차단


# WebSocket (선택)
# KIS_WS_URL=ws://ops.koreainvestment.com:21000   # 실전
# KIS_WS_URL=ws://ops.koreainvestment.com:31000   # 모의
# KIS_WS_APPROVAL_KEY=   # (선택) 직접 넣어도 되지만, 기본은 자동 발급(fetch_approval_key)
# KIS_APPROVAL_MIN_INTERVAL_SEC=62
# KIS_APPROVAL_CACHE_PATH=.kis_approval_cache.json

# 운영 파라미터
CAPITAL_KRW=10000000
PAIRBOT_MAX_POSITION_NOTIONAL_PCT=0.5
PRICE_POLL_INTERVAL_SEC=1.0
LOG_LEVEL=INFO
